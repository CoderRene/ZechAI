############################################
# Copy to `.env` and fill in your secrets #
############################################

# Which provider to use for LiteLLM:
# - lmstudio (default): OpenAI-compatible endpoint (LM Studio, etc.)
# - google: Gemini via Google AI Studio API key
LLM_PROVIDER=lmstudio

# LM Studio OpenAI-compatible base URL
LM_STUDIO_API_BASE=http://192.168.254.117:3002/v1

# If your LM Studio setup requires a token, set it here.
# If LM Studio is configured to accept requests without auth,
# you can leave this blank or omit it entirely.
LM_STUDIO_API_KEY=

# Optional: change the LiteLLM model id used for LM Studio
# (fallback is QWEN_MODEL, then openai/local-model)
LM_STUDIO_MODEL=openai/local-model

# Gemini (Google AI Studio)
# Either variable works; GOOGLE_API_KEY is preferred.
GOOGLE_API_KEY=
GEMINI_API_KEY=

# LiteLLM model id for Gemini, e.g.:
# - gemini/gemini-2.0-flash
# - gemini/gemini-2.0-pro
GOOGLE_MODEL=gemini/gemini-2.0-flash

